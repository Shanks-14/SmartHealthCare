# Server Configuration
PORT=3000
NODE_ENV=development

# Frontend
REACT_APP_API_URL=http://localhost:3000/api
REACT_APP_AZURE_CLIENT_ID=PASTE_CLIENT_ID_HERE
REACT_APP_AZURE_TENANT_NAME=SmartCareB2C
