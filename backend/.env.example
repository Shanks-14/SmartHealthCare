# Database Configuration
DB_SERVER=your-server.database.windows.net
DB_NAME=SmartCareDB
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_PORT=1433

# JWT Configuration
JWT_SECRET=replace_with_a_long_random_secret_string
